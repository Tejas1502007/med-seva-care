# ──────────────────────────────────────────────────────────────────────────────
# MedSeva — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Your Project → Settings → API

# Your project's public URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to expose in the browser (RLS enforces security)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER SIDE ONLY, never expose to the browser
# Used in server functions / API routes only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Supabase Auth (Google OAuth) ──────────────────────────────────────────────
# Set up in: Supabase Dashboard → Authentication → Providers → Google
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials

SUPABASE_AUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:3000
